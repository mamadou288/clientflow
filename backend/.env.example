# Copier en .env et adapter. Toutes ces variables ont des valeurs de repli
# pour le développement — ce fichier documente ce qui est configurable.

# Sécurité
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Base de données — vide = SQLite (dev local hors Docker).
# En Docker/CI : URL Postgres (voir docker-compose.yml).
# DATABASE_URL=postgres://clientflow:clientflow@db:5432/clientflow

# CORS — origines autorisées du frontend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
